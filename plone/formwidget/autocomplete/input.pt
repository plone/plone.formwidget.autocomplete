<script type="text/javascript"
        tal:content="structure view/js"
></script>
<div tal:attributes="
       id string:${view/id}-autocomplete;
     ">
  <div class="autocompleteInputWidget"
       tal:content="structure view/renderQueryWidget"
       tal:attributes="
         id string:${view/id}-input-fields;
       "
  ></div>
  <tal:block replace="structure view/subform/render" />
</div>
